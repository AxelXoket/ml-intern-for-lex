# ============================================================================
# ml-intern — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================================

# ── Required: lex_study_foundation connection ────────────────────
# Absolute path to Python executable in lex_study_foundation's venv
LEX_PYTHON_EXE=C:\path\to\lex_study_foundation\.venv\Scripts\python.exe
# Absolute path to lex_study_foundation repo root
LEX_PROJECT_ROOT=C:\path\to\lex_study_foundation

# ── Optional: integration overrides ─────────────────────────────
# LEX_CONFIG_DIR=C:\path\to\lex_study_foundation\configs
# ML_INTERN_HOST=127.0.0.1
# ML_INTERN_PORT=8642

# ── Optional: research provider tokens ──────────────────────────
# These tokens belong to ml-intern ONLY. They are NEVER forwarded
# to lex_study_foundation subprocesses. Research features are
# disabled by default — set RESEARCH_ENABLED=true to activate.
#
# RESEARCH_ENABLED=false
#
# Anthropic API key (for Claude-backed research features)
# ANTHROPIC_API_KEY=
#
# HuggingFace token (prefer read-only unless write access needed)
# HF_TOKEN=
#
# GitHub token (prefer fine-grained PAT, minimum scope, with expiration)
# GITHUB_TOKEN=

# ── Optional: advanced ──────────────────────────────────────────
# Override .env file path resolution (for non-standard layouts)
# ML_INTERN_ENV_FILE=C:\path\to\custom\.env
